# ── Required ──────────────────────────────────────────────
# Neon connection string (private, server-side only)
DATABASE_URL=postgres://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# ── Optional: AI narrative extraction ─────────────────────
# The UI lets the user pick a provider per crawl. Providers whose
# key is missing are simply hidden from the dropdown.
# Structure (links/categories/sections) is ALWAYS from MediaWiki —
# the LLM only rewrites/condenses the real first paragraph.

CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=...
GEMINI_MODEL=gemini-3.1-pro
